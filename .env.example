# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=production

# Auth — comma-separated API keys (first key = default)
API_KEYS=change-me-secret-key

# Storage
SQLITE_PATH=./data/logserver.db
RETENTION_DAYS=30

# File ingestion (Pino NDJSON structured logs)
LOG_FILE_PATH=./logs/structured.log
FILE_POLL_INTERVAL_MS=1000

# AI Report (OpenAI)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Uptime Kuma (optional)
KUMA_API_URL=
KUMA_API_KEY=
